  },
  "homepage": "https://github.com/jatingyass/Group-Chat-App#readme",
  "keywords": [
    "chat",
    "websocket",
    "socket.io",
    "express",
    "mysql",
    "sequelize",
    "jwt",
    "real-time"
  ],
  "license": "MIT",
