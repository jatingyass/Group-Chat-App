# =============================================================================
# Group Chat App — Environment Variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git.
# =============================================================================

# ----- Server -----
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ----- Database (MySQL) -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=group_chat
DB_USER=root
DB_PASSWORD=changeme

# ----- Sharding (for Messages / ArchivedMessages / ColdMessages) -----
# SHARD_COUNT=1 (default) -> single-DB mode. Identical to non-sharded behavior.
# SHARD_COUNT=2+          -> SHARD_DBS must list that many database names; routing
#                            is groupId % SHARD_COUNT (consistent — same group always
#                            hits same shard). Run `npm run setup:shards` to create
#                            the databases on your MySQL server.
SHARD_COUNT=1
# SHARD_DBS=group_chat_shard_0,group_chat_shard_1


# ----- JWT -----
# Generate a strong secret: `openssl rand -base64 64`
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ----- File Storage -----
# STORAGE_DRIVER=local  -> stores uploads in `./uploads` directory (default for dev)
# STORAGE_DRIVER=s3     -> stores uploads in AWS S3 / MinIO (for production)
STORAGE_DRIVER=local
LOCAL_UPLOAD_PATH=./uploads

# ----- AWS S3 / MinIO (only used if STORAGE_DRIVER=s3) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
# For local MinIO testing, set:
# AWS_S3_ENDPOINT=http://localhost:9000
# AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# ----- Optional: Redis (for horizontal Socket.IO scaling) -----
# When set, multiple backend instances stay in sync via Redis pub/sub so a
# message broadcast from one instance reaches sockets on every other instance.
# Leave blank for single-instance dev.
# REDIS_URL=redis://localhost:6379

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----- Logging -----
LOG_LEVEL=info
